# YouTube Data API Key (optional - fallback uses known video IDs)
YOUTUBE_API_KEY=

# Vercel KV (for production session management)
# When KV_REST_API_URL is set, sessions survive redeploys.
# Without it, an in-memory fallback is used (local dev only).
# Set these via `vercel env pull` or the Vercel dashboard.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Admin panel password (required to access /admin)
ADMIN_PASSWORD=

# Fan club member credentials (JSON string)
# Format: {"FC001":"password1","FC002":"password2"}
# If not set, falls back to hardcoded demo credentials (dev only).
FC_MEMBERS=
